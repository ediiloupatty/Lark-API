# ─────────────────────────────────────────────────────────────────────────────
# LARK LAUNDRY — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# CARA PAKAI:
#   1. Salin file ini → cp .env.example .env
#   2. Isi nilai yang kosong sesuai environment kamu
#   3. JANGAN commit file .env ke Git (sudah ada di .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# PENTING: Karakter spesial di password harus di-URL-encode
#   ! → %21   @ → %40   # → %23   $ → %24
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/db_laundry?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_DB_PASSWORD_HERE
POSTGRES_DB=db_laundry

# ── JWT (Authentication) ──────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=YOUR_RANDOM_JWT_SECRET_MIN_128_CHARS

# ── Email (Nodemailer via Gmail) ──────────────────────────────────────────────
# Gmail App Password: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_gmail_app_password
MAIL_FROM="LarkLaundry <your_email@gmail.com>"

# ── App URL ───────────────────────────────────────────────────────────────────
# Development: http://localhost:5173
# Production:  https://larklaundry.com
APP_URL=https://larklaundry.com
VITE_FRONTEND_URL=https://larklaundry.com
BACKEND_URL=https://api.larklaundry.com

# ── Mayar Payment Gateway ─────────────────────────────────────────────────────
# API Key: https://web.mayar.id/api-keys
# Webhook secret: dari dashboard Mayar → Settings → Webhook
# Webhook URL yang didaftarkan ke Mayar: https://api.larklaundry.com/api/v1/payments/notify
MAYAR_API_KEY=YOUR_MAYAR_API_KEY
MAYAR_WEBHOOK_SECRET=YOUR_MAYAR_WEBHOOK_SECRET
MAYAR_DEFAULT_EMAIL=your_email@gmail.com

# ── Google OAuth (SSO) ────────────────────────────────────────────────────────
# Dari Google Cloud Console → Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ── Maintenance Mode ──────────────────────────────────────────────────────────
# Set ke "true" untuk maintenance, lalu RESTART backend
MAINTENANCE_MODE=false
MAINTENANCE_MSG=Sistem sedang dalam pemeliharaan terjadwal. Kami akan kembali segera.
# MAINTENANCE_UNTIL=17 April 2026, pukul 04.00 WIB

# ── Cloudflare R2 (Object Storage — Bukti Pembayaran) ──────────────────────
# Dari Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=lark-uploads
R2_PUBLIC_URL=https://pub-YOUR_ID.r2.dev
