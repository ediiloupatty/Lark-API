# ── Test Environment — TEMPLATE ─────────────────────────────────
# Copy file ini menjadi .env.test sebelum menjalankan test.
# cp .env.test.example .env.test
#
# Di GitHub Actions, env variables di-set langsung di workflow YAML.

NODE_ENV=test

# Database — ganti dengan database test lokal kamu
DATABASE_URL="postgresql://postgres:secret@localhost:5432/db_laundry?schema=public"

# JWT Secret — sama dengan .env
JWT_SECRET="your-jwt-secret-here"

# Maintenance mode OFF saat test
MAINTENANCE_MODE=false

# Dummy values — tidak dipakai saat test
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=test@test.com
MAIL_PASS=dummy
MAIL_FROM="Test <test@test.com>"
APP_URL=http://localhost:5173
GOOGLE_CLIENT_ID=dummy
GEMINI_API_KEY=dummy
